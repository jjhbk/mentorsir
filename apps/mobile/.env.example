# Android release signing (used by android/app/build.gradle)
MENTORSIR_UPLOAD_STORE_FILE=../../mentorsir-release.keystore
MENTORSIR_UPLOAD_STORE_PASSWORD=
MENTORSIR_UPLOAD_KEY_ALIAS=mentorsir
MENTORSIR_UPLOAD_KEY_PASSWORD=

# Optional fallback (used if MENTORSIR_UPLOAD_STORE_PASSWORD is empty)
PASSWORD=
