generator client {
  provider        = "prisma-client"
  output          = "../lib/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ── Profiles ───────────────────────────────────────────────────────────────────
// id mirrors auth.users(id) — created by Supabase trigger on sign-up
model Profile {
  id               String   @id @db.Uuid
  role             Role     @default(student)
  name             String?
  mobile           String?
  telegramId       String?  @map("telegram_id")
  medium           String?
  graduationStream String?  @map("graduation_stream")
  mentorId         String?  @map("mentor_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  assignedMentor      Profile?  @relation("MentorStudents", fields: [mentorId], references: [id], onDelete: SetNull)
  assignedStudents    Profile[] @relation("MentorStudents")
  intakeForm          IntakeForm?
  dailyLogs           DailyLog[]
  scheduleEntries     ScheduleEntry[]
  testResults         TestResult[]
  studentAudit        StudentAudit?
  mentorAccessRequest MentorAccessRequest?
  planSubscriptions   PlanSubscription[]
  seedhapeOrders      SeedhaPeOrder[]
  yearlyPlanEntries   YearlyPlanEntry[]
  alternateScheduleEntries AlternateScheduleEntry[]
  resourceMappings    ResourceMappingEntry[] @relation("ResourceMappingOwner")

  @@map("profiles")
}

enum Role {
  student
  mentor
}

enum MentorRequestStatus {
  pending
  approved
  rejected
}

enum SubscriptionPlanCode {
  ptp_3m
  mtp_2_3m
}

enum SeedhaPeOrderStatus {
  created
  pending
  verified
  disputed
  resolved
  expired
  rejected
}

// ── Intake Forms ───────────────────────────────────────────────────────────────
// 27-field enrollment questionnaire
model IntakeForm {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String   @unique @map("user_id") @db.Uuid
  mobile                String?
  email                 String?
  medium                String?
  graduationStream      String?  @map("graduation_stream")
  prelimsExperience     String?  @map("prelims_experience")
  attemptCount          Int      @default(0) @map("attempt_count")
  gsScoreBand           String?  @map("gs_score_band")
  personalDifficulties  String?  @map("personal_difficulties")
  strongGsSubjects      String[] @map("strong_gs_subjects")
  weakGsSubjects        String[] @map("weak_gs_subjects")
  currentAffairsSource  String?  @map("current_affairs_source")
  csatStrongArea        String?  @map("csat_strong_area")
  csatWeakArea          String?  @map("csat_weak_area")
  csatScoreBand         String?  @map("csat_score_band")
  mockFrequency         String?  @map("mock_frequency")
  testAnalysis          String?  @map("test_analysis")
  wrongQuestionRevision String?  @map("wrong_question_revision")
  pyqPractice           String?  @map("pyq_practice")
  planConsistency       String?  @map("plan_consistency")
  dailyStudyHours       String?  @map("daily_study_hours")
  revisionCount         String?  @map("revision_count")
  sourcesPerSubject     String?  @map("sources_per_subject")
  coreChallenges        String[] @map("core_challenges")
  mentorshipExpectations String[] @map("mentorship_expectations")
  discoveryPlatform     String?  @map("discovery_platform")
  notes                 String?
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("intake_forms")
}

// ── Daily Logs ─────────────────────────────────────────────────────────────────
// One row per student per day — core accountability tracking
model DailyLog {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String        @map("user_id") @db.Uuid
  date                  DateTime      @db.Date
  studyHours            Decimal       @default(0) @map("study_hours") @db.Decimal(4, 1)
  sleepHours            Decimal       @default(0) @map("sleep_hours") @db.Decimal(4, 1)
  meditationMinutes     Int           @default(0) @map("meditation_minutes")
  sleepTime             String?       @map("sleep_time")
  wakeTime              String?       @map("wake_time")
  taskCompleted         TaskStatus?   @map("task_completed")
  afternoonNapMinutes   Int           @default(0) @map("afternoon_nap_minutes")
  hadMentorDiscussion   Boolean       @default(false) @map("had_mentor_discussion")
  relaxationActivity    String?       @map("relaxation_activity")
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_logs")
}

enum TaskStatus {
  yes
  no
  partial
}

// ── Schedule Entries ───────────────────────────────────────────────────────────
// Mentor-assigned PTP 2.0 weekly study plan
model ScheduleEntry {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String      @map("user_id") @db.Uuid
  date         DateTime    @db.Date
  subject      String?
  syllabus     String?
  primarySource String?    @map("primary_source")
  entryType    EntryType   @default(study) @map("entry_type")
  completed    Boolean     @default(false)
  revision1    Boolean     @default(false)
  revision2    Boolean     @default(false)
  revision3    Boolean     @default(false)

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("schedule_entries")
}

enum EntryType {
  study
  ca_test        @map("ca-test")
  sectional_test @map("sectional-test")
  mentor_connect @map("mentor-connect")
}

// ── Test Results ───────────────────────────────────────────────────────────────
// Prelims mock test scores + 8-category mistake breakdown
model TestResult {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                  String   @map("user_id") @db.Uuid
  testName                String   @map("test_name")
  date                    DateTime @db.Date
  score                   Decimal? @db.Decimal(5, 1)
  totalQuestions          Int?     @map("total_questions")
  mistakeConceptual       Int      @default(0) @map("mistake_conceptual")
  mistakeRecall           Int      @default(0) @map("mistake_recall")
  mistakeReading          Int      @default(0) @map("mistake_reading")
  mistakeElimination      Int      @default(0) @map("mistake_elimination")
  mistakeDecisionMaking   Int      @default(0) @map("mistake_decision_making")
  mistakeSilly            Int      @default(0) @map("mistake_silly")
  mistakePsychological    Int      @default(0) @map("mistake_psychological")
  mistakePatternMisjudgment Int    @default(0) @map("mistake_pattern_misjudgment")
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("test_results")
}

// ── Student Audits ─────────────────────────────────────────────────────────────
// Mentor-maintained academic & personality profile per student
model StudentAudit {
  userId                 String   @id @map("user_id") @db.Uuid
  strongAcademicSubjects String[] @default([]) @map("strong_academic_subjects")
  weakAcademicSubjects   String[] @default([]) @map("weak_academic_subjects")
  strongPersonalityTraits String[] @default([]) @map("strong_personality_traits")
  weakPersonalityTraits  String[] @default([]) @map("weak_personality_traits")
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student_audits")
}

// ── Mentor Access Requests ───────────────────────────────────────────────────
// Users can request mentor access; admins approve/reject these requests.
model MentorAccessRequest {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String              @unique @map("user_id") @db.Uuid
  status          MentorRequestStatus @default(pending)
  requestedAt     DateTime            @default(now()) @map("requested_at") @db.Timestamptz
  reviewedAt      DateTime?           @map("reviewed_at") @db.Timestamptz
  reviewedBy      String?             @map("reviewed_by") @db.Uuid
  rejectionReason String?             @map("rejection_reason")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("mentor_access_requests")
}

// ── Contact Submissions ─────────────────────────────────────────────────────
// Public website contact form submissions for admin follow-up.
model ContactSubmission {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  phone     String
  email     String
  message   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([createdAt])
  @@map("contact_submissions")
}

// ── Plan Subscriptions ───────────────────────────────────────────────────────
// Purchase intent records for available plans (payment integration pending).
model PlanSubscription {
  id        String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String               @map("user_id") @db.Uuid
  planCode  SubscriptionPlanCode @map("plan_code")
  planName  String               @map("plan_name")
  amountInr Int                  @map("amount_inr")
  active    Boolean              @default(true)
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([active, createdAt])
  @@unique([userId, planCode])
  @@map("plan_subscriptions")
}

// ── SeedhaPe Orders ─────────────────────────────────────────────────────────
// Payment orders created through SeedhaPe.
model SeedhaPeOrder {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String               @map("user_id") @db.Uuid
  planCode        SubscriptionPlanCode @map("plan_code")
  planName        String               @map("plan_name")
  amountPaise     Int                  @map("amount_paise")
  externalOrderId String               @unique @map("external_order_id")
  seedhapeOrderId String               @unique @map("seedhape_order_id")
  status          SeedhaPeOrderStatus  @default(created)
  upiUri          String?              @map("upi_uri")
  qrCode          String?              @map("qr_code")
  expiresAt       DateTime?            @map("expires_at") @db.Timestamptz
  verifiedAt      DateTime?            @map("verified_at") @db.Timestamptz
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("seedhape_orders")
}

// ── Resource Mapping ─────────────────────────────────────────────────────────
// Mentor-owned subject-to-resource mapping rows.
model ResourceMappingEntry {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId            String   @map("owner_id") @db.Uuid
  subject            String
  part               String?
  resource           String?
  prelimsPyqPractice String?  @map("prelims_pyq_practice")
  mainsPyq           String?  @map("mains_pyq")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  owner Profile @relation("ResourceMappingOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, createdAt])
  @@map("resource_mapping_entries")
}

// ── Yearly Plan ──────────────────────────────────────────────────────────────
// Student yearly plan rows with up to three subject focuses per month.
model YearlyPlanEntry {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  month     String
  subject1  String?  @map("subject_1")
  subject2  String?  @map("subject_2")
  subject3  String?  @map("subject_3")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, createdAt])
  @@map("yearly_plan_entries")
}

// ── Alternate Schedule ───────────────────────────────────────────────────────
// Flexible day-level alternate schedule notes for students.
model AlternateScheduleEntry {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  date      DateTime @db.Date
  focus     String?
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("alternate_schedule_entries")
}

// ── Mentor Chat ───────────────────────────────────────────────────────────────
// Private mentor-student chat messages.
model ChatMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mentorId  String   @map("mentor_id") @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  senderId  String   @map("sender_id") @db.Uuid
  message   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  readAt    DateTime? @map("read_at") @db.Timestamptz

  @@index([mentorId, studentId, createdAt])
  @@index([studentId, createdAt])
  @@index([mentorId, createdAt])
  @@map("chat_messages")
}

// ── Mentor Meetings ───────────────────────────────────────────────────────────
// Scheduled mentor-student meetings and private notes from both sides.
model MentorMeeting {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mentorId       String   @map("mentor_id") @db.Uuid
  studentId      String   @map("student_id") @db.Uuid
  scheduledAt    DateTime @map("scheduled_at") @db.Timestamptz
  mode           String?  // online / call / in-person
  meetingLink    String?  @map("meeting_link")
  agenda         String?
  studentNotes   String?  @map("student_notes")
  mentorNotes    String?  @map("mentor_notes")
  createdBy      String   @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([mentorId, scheduledAt])
  @@index([studentId, scheduledAt])
  @@index([mentorId, studentId, scheduledAt])
  @@map("mentor_meetings")
}
